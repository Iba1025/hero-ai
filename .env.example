# Hero.AI environment variables — copy to .env and fill in values.
# All config via pydantic-settings in src/hero/config.py (spec §3).

# ── Postgres (ca-central instance) ────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://hero:hero@localhost:5432/hero

# ── Qdrant (DEC-3) ───────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── R2 / S3 object storage (INV-3: presigning only; ca jurisdiction) ─
R2_ENDPOINT=
R2_BUCKET=hero-media
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REGION=auto

# ── Langfuse (self-hosted, ca-central — INV-2) ──────────────────────
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── VLM tiered routing (DEC-18) ─────────────────────────────────────
VLM_MODEL_PRIMARY=claude-fable-5          # DIAGNOSE/TRIAGE (reasoning-heavy)
VLM_MODEL_VERIFY=claude-sonnet-4-6        # decompose_claims/check_entailment (high-volume)
VLM_MODEL_FALLBACK=gpt-4o                 # cross-provider fallback for both tiers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Adapter selectors (swappable interfaces) ────────────────────────
EMBEDDER_IMPL=stub
RERANKER_IMPL=stub
CALIBRATOR_IMPL=platt                     # default (DEC-5); isotonic self-gates <1000 labels

# ── Retrieval / verification tuning ─────────────────────────────────
GROUNDING_THRESHOLD=0.8                   # VERIFY threshold, descriptive claims (BL-6/DEC-6)
GROUNDING_THRESHOLD_STRICT=1.0            # VERIFY threshold, part-number/model-code claims (BL-6)
MAX_CLARIFY_ROUNDS=3
MAX_CORRECTIVE_ROUNDS=2
CORRECTIVE_TIMEOUT_S=10.0

# ── Dev-only flags (NEVER set in CI/prod) ───────────────────────────
# HERO_EVAL_MEMORY_CHECKPOINTER=1  # Use MemorySaver instead of PostgresSaver.
#                                   # Local dev convenience ONLY when no Postgres available.
#                                   # INV-6 requires persistent checkpoints in all real runs.
